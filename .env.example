# Copy to .env and adjust. Everything here has a sensible default; nothing is required
# to run against a local offline server with the CLI AI backend.

# ─── AI backend ──────────────────────────────────────────────────────────────
# This build ships CLI-only: it drives the `claude` CLI (`claude -p`) as the AI
# backend, so it uses your existing Claude subscription / browser login — no API
# key required. Install and log in once:
#   npm i -g @anthropic-ai/claude-code && claude   (then follow the login prompt)
#
# The provider layer (ai-provider.js) is pluggable — an "anthropic-api" backend is
# stubbed out for anyone who wants direct-API auth instead. See the README.
AI_PROVIDER=claude-code
# Model for the main reasoning loop — any id the claude CLI accepts.
#AI_MODEL=claude-sonnet-4-5

# ─── Minecraft server to join ────────────────────────────────────────────────
# Defaults target a local offline server (see scripts/setup-server.sh).
#MC_HOST=localhost
#MC_PORT=25565
#MC_VERSION=1.21.11

# Bot's in-game username.
#MC_USERNAME=Bro

# Auth mode: 'offline' for a cracked/LAN server (this is the default behaviour),
# 'microsoft' for an online-mode server (needs a Microsoft account + interactive login).
#MC_AUTH=offline

# When MC_HOST is remote AND an http(s)_proxy env var is set, the bot tunnels the
# Minecraft connection through it via HTTP CONNECT. Local hosts always connect directly.

# ─── Data location ───────────────────────────────────────────────────────────
# Per-bot generated state (blocks.db, logs, chat-logs, task-stack, block memory)
# defaults to your OS user-data dir under an `iongolem/<username>/` folder:
#   Linux:   ~/.local/share/iongolem/    (or $XDG_DATA_HOME)
#   macOS:   ~/Library/Application Support/iongolem/
#   Windows: %LOCALAPPDATA%\iongolem\
# So it survives re-cloning the repo. Override the base dir here — e.g. set it to
# ./runtime to keep everything next to the code (handy for hacking / quick reset).
#IONGOLEM_DATA_DIR=./runtime
